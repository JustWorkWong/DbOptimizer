{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "DbOptimizer": {
    "ConnectionStrings": {
      "PostgreSql": "Host=localhost;Port=5432;Database=dboptimizer;Username=postgres",
      "Redis": "localhost:6379",
      "MySql": "Server=localhost;Port=3306;Database=dboptimizer;Uid=root"
    },
    "Ai": {
      "Endpoint": "https://api.openai.com/v1",
      "Model": "gpt-4o-mini",
      "ApiKey": "",
      "ApiKeyEnvVar": "OPENAI_API_KEY",
      "RequestTimeoutSeconds": 60,
      "MaxTokens": 50000
    },
    "Mcp": {
      "MySql": {
        "Enabled": true,
        "Transport": "stdio",
        "Command": "npx",
        "Arguments": "-y @modelcontextprotocol/server-mysql"
      },
      "PostgreSql": {
        "Enabled": true,
        "Transport": "stdio",
        "Command": "npx",
        "Arguments": "-y @modelcontextprotocol/server-postgres"
      },
      "TimeoutSeconds": 30,
      "RetryCount": 2,
      "RetryDelayMilliseconds": 1000,
      "EnableDirectDbFallback": true,
      "EnableAuditLogging": true
    },
    "Workflow": {
      "StepTimeoutSeconds": 120,
      "MaxRetryCount": 3,
      "RegenerationMaxRounds": 3
    }
  }
}
