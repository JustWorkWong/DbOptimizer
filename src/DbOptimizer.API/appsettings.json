{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DbOptimizer": {
    "ConnectionStrings": {
      "PostgreSql": "Host=localhost;Port=5432;Database=dboptimizer;Username=postgres",
      "MySql": "Server=localhost;Port=3306;Database=dboptimizer;Uid=root"
    },
    "ExecutionPlan": {
      "MySql": {
        "Enabled": true,
        "Transport": "stdio",
        "Command": "npx",
        "Arguments": "-y @modelcontextprotocol/server-mysql"
      },
      "PostgreSql": {
        "Enabled": true,
        "Transport": "stdio",
        "Command": "npx",
        "Arguments": "-y @modelcontextprotocol/server-postgres"
      },
      "TimeoutSeconds": 30,
      "RetryCount": 2,
      "RetryDelayMilliseconds": 1000,
      "EnableDirectDbFallback": true
    }
  },
  "AllowedHosts": "*"
}
